# ============================================================
# TalentForge — Variáveis de ambiente unificadas
# Copie este arquivo e preencha os valores:
#   .env.local          → raiz do monorepo
#   apps/web/.env.local → frontend Next.js
#   apps/api/.env       → backend NestJS
#
# ⚠️ NUNCA adicionar VERCEL_OIDC_TOKEN — causa hang do servidor local
# ============================================================

# ------------------------------------------------------------
# SUPABASE (obter em: Supabase → Project Settings → API)
# ------------------------------------------------------------
NEXT_PUBLIC_SUPABASE_URL=https://<project-ref>.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=<anon-key>
SUPABASE_URL=https://<project-ref>.supabase.co
SUPABASE_ANON_KEY=<anon-key>
SUPABASE_SERVICE_ROLE_KEY=<service-role-key>
SUPABASE_JWT_SECRET=<jwt-secret>

# ------------------------------------------------------------
# API / FRONTEND
# ------------------------------------------------------------
NEXT_PUBLIC_API_URL=http://localhost:3001/api/v1
FRONTEND_URL=http://localhost:3000
PORT=3001

# ------------------------------------------------------------
# GOOGLE CALENDAR (obter em: Google Cloud → Credenciais)
# ------------------------------------------------------------
GOOGLE_CALENDAR_CLIENT_ID=<google-client-id>
GOOGLE_CALENDAR_CLIENT_SECRET=<google-client-secret>
GOOGLE_CALENDAR_REDIRECT_URL=http://127.0.0.1:3001/api/v1/auth/google-calendar/callback

# ------------------------------------------------------------
# BREVO SMTP (obter em: Brevo → SMTP & API → SMTP)
# SMTP_USER  = e-mail de login da conta Brevo
# SMTP_PASS  = SMTP Key gerada em "SMTP Keys" (≠ senha da conta!)
# ------------------------------------------------------------
BREVO_SMTP_HOST=smtp-relay.brevo.com
BREVO_SMTP_PORT=587
BREVO_SMTP_USER=<seu-email-de-login-brevo>
BREVO_SMTP_PASS=<smtp-key-gerada-no-painel-brevo>
BREVO_SENDER_EMAIL=<email-remetente-verificado>
BREVO_SENDER_NAME=TalentForge
