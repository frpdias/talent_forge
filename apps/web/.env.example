# ============================================================
# apps/web/.env.local — Frontend Next.js
# ============================================================

# Supabase (públicos — usados no browser)
NEXT_PUBLIC_SUPABASE_URL=https://<project-ref>.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=<anon-key>

# Service role (usado apenas em Server Components / Route Handlers)
SUPABASE_SERVICE_ROLE_KEY=<service-role-key>

# ⚠️ NUNCA adicionar VERCEL_OIDC_TOKEN aqui — causa hang do servidor local
